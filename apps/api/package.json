{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/orchestrator/worker-standalone.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "backfill-embeddings": "tsx src/scripts/backfill-embeddings.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "8.x",
    "@prisma/client": "^5.0.0",
    "@repo/model-gateway": "workspace:*",
    "@repo/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "fastify-sse-v2": "^4.2.2",
    "ioredis": "^5.11.1",
    "pdfkit": "^0.19.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
