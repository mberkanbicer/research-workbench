# Server
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# Database / Queue
DATABASE_URL=postgresql://research:research@localhost:5432/research_workbench?schema=public
REDIS_URL=redis://localhost:6379

# Model providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=

# Search providers
SEARCH_PROVIDER=web
MOCK_SEARCH_FIXTURE_PATH=./templates/mock-search-results.json
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=

# Security
API_KEY_ENCRYPTION_SECRET=dev-only-change-me-32-byte-minimum

# Rate Limiting
AUTH_RATE_LIMIT_MAX=20        # Max login/register attempts per IP per window
AUTH_RATE_LIMIT_WINDOW_MS=60000  # Window in milliseconds (default: 1 min)
API_RATE_LIMIT_MAX=200        # Max general API requests per IP per window
API_RATE_LIMIT_WINDOW_MS=60000   # Window in milliseconds (default: 1 min)
