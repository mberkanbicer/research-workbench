# Server
# NODE_ENV is managed by Next.js/tooling — do not set here unless deploying to production
# API_PORT is used by the API server
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000

# Database / Queue (ports match docker-compose.yml)
DATABASE_URL=postgresql://research:research@localhost:5433/research_workbench?schema=public
REDIS_URL=redis://localhost:6380

# Model providers
# OpenRouter (get key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
# OpenAI-compatible (e.g., LocalAI, LM Studio)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=

# Search providers
# mock = deterministic fixtures, no API key needed; web = SearXNG or custom
SEARCH_PROVIDER=mock
MOCK_SEARCH_FIXTURE_PATH=./templates/mock-search-results.json
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=

# Advanced: SearXNG instance (alternative to SerpAPI for web search)
SEARXNG_BASE_URL=https://search.bicers.me

# Embeddings (optional — improves context selection on large projects)
EMBEDDING_ENABLED=false
# mock = deterministic local vectors; openai = text-embedding-3-small via API
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
# Set true after running infra/postgres/migrations/0002_pgvector_embeddings_optional.sql
PGVECTOR_ENABLED=false

# Security
API_KEY_ENCRYPTION_SECRET=dev-only-change-me-32-byte-minimum
