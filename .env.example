# Server
# NODE_ENV is managed by Next.js/tooling — do not set here unless deploying to production
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000

# Database / Queue (ports match docker-compose.yml)
DATABASE_URL=postgresql://research:research@localhost:5433/research_workbench?schema=public
REDIS_URL=redis://localhost:6380

# Model providers
# OpenRouter (get key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
# OpenAI-compatible (e.g., LocalAI, LM Studio)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=

# Search providers
# mock = deterministic fixtures, no API key needed; web = SearXNG or custom
SEARCH_PROVIDER=mock
MOCK_SEARCH_FIXTURE_PATH=./templates/mock-search-results.json
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=
SEARXNG_BASE_URL=
SERPAPI_API_KEY=

# Embeddings (optional — improves context selection on large projects)
EMBEDDING_ENABLED=false
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
PGVECTOR_ENABLED=false

# Security
API_KEY_ENCRYPTION_KEY=dev-only-change-me-32-byte-minimum

# Rate limiting
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Session
SESSION_EXPIRY_MS=604800000

# SSE / Presence polling
SSE_HEARTBEAT_MS=30000
SSE_POLL_INITIAL_MS=1000
SSE_POLL_MAX_MS=30000
SSE_RETRY_MS=5000
PRESENCE_POLL_MS=5000
PRESENCE_ONLINE_MS=15000
PRESENCE_OFFLINE_MS=30000

# Content limits
DEFAULT_TOKEN_BUDGET=8000
EMBEDDING_INPUT_MAX_CHARS=8000
MESSAGE_CONTENT_MAX_CHARS=4000
RESPONSE_TEXT_MAX_CHARS=10000
STALE_THRESHOLD_DAYS=180

# Frontend (Next.js — must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Testing (CI only)
RUN_LIVE_TESTS=false
REAL_SEARCH_URL=
REAL_TEST_API_KEY=
REAL_OLLAMA_BASE_URL=
